---
import MainLayout from '../layouts/MainLayout.astro';

const heroImage = "https://imagedelivery.net/-sPAUAWeA405NiWJ0SNIQA/f82386a7-bc22-4685-5b00-a3b7de817400/public";
const contactEmail = "sales@desertrich.com";
const subjectLine = "Acquisition Inquiry — wearableroboticexoskeletons.com";
const mailtoLink = `mailto:${contactEmail}?subject=${encodeURIComponent(subjectLine)}`;

const marketStats = [
  { value: "15–22%+", label: "Compound Annual Growth Rate", detail: "Industry consensus CAGR through 2030–2033" },
  { value: "$2B+", label: "Projected Market Size", detail: "Forecast to exceed $2 billion by early 2030s" },
  { value: "4", label: "Primary Growth Verticals", detail: "Healthcare, Industrial, Defense, Consumer/Wearables" },
  { value: "2026", label: "Strategic Entry Window", detail: "Optimal timing — technology is maturing, adoption accelerating" },
];

const valueDrivers = [
  {
    num: "01",
    title: "Exact-Match Category Leadership",
    desc: "It literally <em>is</em> the term people will use when searching for or discussing wearable robotic exoskeletons. This delivers instant relevance, trust, and branding power that generic or invented names cannot match."
  },
  {
    num: "02",
    title: "Memorability + Descriptiveness",
    desc: "Long enough to be fully self-explanatory and SEO-aligned, yet rhythmic and pronounceable. It builds immediate credibility and reduces customer education costs."
  },
  {
    num: "03",
    title: "SEO & Traffic Advantage",
    desc: "Perfect alignment with high-intent, long-tail searches. As public and B2B awareness explodes, this domain becomes a natural magnet for organic traffic, media mentions, and thought leadership."
  },
  {
    num: "04",
    title: "Brand Protection & Moat",
    desc: "Owning the definitive term prevents competitors from claiming category ownership. It is the ultimate defensive and offensive branding asset."
  },
  {
    num: "05",
    title: "Versatility & Development Potential",
    desc: "Ideal foundation for a flagship corporate site, industry news portal, B2B/B2C marketplace, research or policy hub, investor resource, or consumer education platform."
  },
  {
    num: "06",
    title: "Future-Proof Positioning",
    desc: "As the technology scales from medical/industrial niches into broader commercial and consumer markets, this name scales with it. No rebranding required."
  },
  {
    num: "07",
    title: "Investment & Appreciation Thesis",
    desc: "Premium exact-match domains in nascent, high-growth tech and health categories have historically delivered strong returns. Acquiring now — before mainstream adoption — positions the owner ahead of the curve."
  },
];

const buyerProfiles = [
  "An established or emerging manufacturer seeking instant authority",
  "A visionary building the go-to industry resource or marketplace",
  "An investor or strategic acquirer capturing appreciating tech real estate",
  "A defense, industrial, or healthcare organization consolidating leadership",
];
---

<MainLayout>
  <!-- ============================================ -->
  <!-- NAVBAR                                       -->
  <!-- ============================================ -->
  <nav class="fixed top-0 left-0 right-0 z-50 glass border-b border-exo-border/60">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 h-18 flex items-center justify-between">
      <div class="flex items-center gap-2.5">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-exo-blue to-exo-cyan flex items-center justify-center flex-shrink-0">
          <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <circle cx="12" cy="6" r="2"/>
            <path d="M4 18 L12 6 L20 18"/>
          </svg>
        </div>
        <span class="hidden sm:inline font-mono text-sm font-semibold tracking-tight text-white/90 truncate">
          wearableroboticexoskeletons.com
        </span>
      </div>
      <a href={mailtoLink}
         class="px-5 py-2 text-xs sm:text-sm font-semibold rounded-full border border-exo-blue/40 hover:bg-exo-blue hover:text-white transition-all duration-300 text-exo-blue-bright whitespace-nowrap">
        INQUIRE TO ACQUIRE
      </a>
    </div>
  </nav>

  <!-- ============================================ -->
  <!-- HERO                                         -->
  <!-- ============================================ -->
  <section class="relative min-h-screen flex items-center justify-center pt-18 overflow-hidden">
    <!-- Background layers -->
    <div class="absolute inset-0 dot-grid"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-exo-black/60 via-transparent to-exo-black"></div>

    <!-- Hero image (Cloudflare Images CDN) -->
    <div class="absolute inset-0 opacity-30 sm:opacity-40">
      <img
        src={heroImage}
        alt="Wearable Robotic Exoskeleton — premium high-tech human augmentation"
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-exo-black via-exo-black/50 to-transparent"></div>
    </div>

    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 pt-12 pb-24 text-center">
      <!-- Status badge -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-exo-blue/30 mb-8 animate-fade-in">
        <div class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse-slow"></div>
        <span class="font-mono text-[11px] sm:text-xs tracking-[1.5px] uppercase text-exo-silver">
          Premium .COM Domain — Available for Acquisition
        </span>
      </div>

      <!-- Headline -->
      <h1 class="text-4xl sm:text-6xl md:text-7xl lg:text-[80px] font-extrabold tracking-tighter leading-[1.05] mb-6 animate-slide-up text-white">
        Own the Future<br class="hidden sm:block" /> of Human<br class="sm:hidden" /> Augmentation
      </h1>

      <!-- Subheadline -->
      <p class="max-w-[680px] mx-auto text-lg sm:text-xl lg:text-2xl text-white/70 mb-10 leading-relaxed">
        wearableroboticexoskeletons.com — The exact-match, authoritative .com domain
        for the wearable robotic exoskeleton industry.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href={mailtoLink}
           class="cta-primary px-8 sm:px-10 py-4 rounded-full text-white font-semibold text-base sm:text-lg inline-flex items-center gap-2">
          Inquire to Acquire
          <span class="text-white/70 text-sm font-mono">(Premium Valuation)</span>
        </a>
        <a href={mailtoLink}
           class="cta-secondary px-8 sm:px-10 py-4 rounded-full text-white/80 font-medium text-base sm:text-lg inline-flex items-center gap-2">
          Request Information Package
          <span class="text-exo-blue-bright">→</span>
        </a>
      </div>

      <!-- Trust signals -->
      <div class="flex flex-wrap items-center justify-center gap-5 mt-10 text-xs text-exo-silver font-mono">
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          Escrow-Protected Transaction
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-exo-blue-bright" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          Premium .COM Asset
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-exo-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          Serious Inquiries Only
        </span>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- ADVENT OF EXOSKELETONS                       -->
  <!-- ============================================ -->
  <section class="relative max-w-4xl mx-auto px-4 sm:px-6 py-24 lg:py-32">
    <div class="mb-4 font-mono text-xs tracking-[3px] uppercase text-exo-blue-bright">The Technology</div>
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-8 leading-tight">
      The Advent of Wearable<br class="hidden sm:block" /> Robotic Exoskeletons
    </h2>
    <div class="space-y-6 text-white/75 text-base sm:text-lg leading-relaxed">
      <p>
        What was once the realm of science fiction is now engineering reality. Wearable robotic exoskeletons — powered,
        sensor-driven suits that enhance human strength, endurance, mobility, and safety — are transitioning from clinical
        trials and military prototypes into commercial deployment across healthcare, industry, defense, and beyond.
      </p>
      <p>
        Breakthroughs in lightweight materials, high-torque actuators, AI-powered motion control, intuitive interfaces,
        and energy systems have dramatically improved comfort, affordability, and performance. Devices once limited to
        specialized rehabilitation centers are now appearing on factory floors, in warehouses, and in forward-thinking
        eldercare and wellness applications.
      </p>
      <p class="font-medium text-white/90">
        The timing is exceptional. The market is entering an accelerated growth phase driven by:
      </p>
    </div>
    <div class="grid sm:grid-cols-2 gap-4 mt-8">
      <div class="glass rounded-2xl p-6 border border-exo-border/40">
        <div class="w-8 h-8 rounded-lg bg-exo-blue/20 flex items-center justify-center mb-3">
          <svg class="w-4 h-4 text-exo-blue-bright" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </div>
        <p class="text-white/85 text-sm sm:text-base">Aging global populations and rising demand for mobility restoration and active aging solutions</p>
      </div>
      <div class="glass rounded-2xl p-6 border border-exo-border/40">
        <div class="w-8 h-8 rounded-lg bg-exo-blue/20 flex items-center justify-center mb-3">
          <svg class="w-4 h-4 text-exo-blue-bright" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
        </div>
        <p class="text-white/85 text-sm sm:text-base">Urgent needs to reduce workplace musculoskeletal injuries and boost industrial productivity</p>
      </div>
      <div class="glass rounded-2xl p-6 border border-exo-border/40">
        <div class="w-8 h-8 rounded-lg bg-exo-blue/20 flex items-center justify-center mb-3">
          <svg class="w-4 h-4 text-exo-blue-bright" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
        </div>
        <p class="text-white/85 text-sm sm:text-base">Defense modernization programs seeking enhanced soldier performance and endurance</p>
      </div>
      <div class="glass rounded-2xl p-6 border border-exo-border/40">
        <div class="w-8 h-8 rounded-lg bg-exo-blue/20 flex items-center justify-center mb-3">
          <svg class="w-4 h-4 text-exo-blue-bright" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        <p class="text-white/85 text-sm sm:text-base">Maturing technology — lighter, smarter, more affordable, and regulatory-cleared for broader use</p>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- MARKET OPPORTUNITY                           -->
  <!-- ============================================ -->
  <section class="relative max-w-5xl mx-auto px-4 sm:px-6 py-24 lg:py-32 border-t border-exo-border/40">
    <div class="mb-4 font-mono text-xs tracking-[3px] uppercase text-exo-cyan">Market Overview</div>
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-6 leading-tight">
      Explosive Market Opportunity
    </h2>
    <p class="max-w-3xl text-white/70 text-base sm:text-lg mb-12 leading-relaxed">
      Industry analyses consistently project robust, double-digit growth for the exoskeleton sector. The broader market,
      valued in the hundreds of millions to low billions in the mid-2020s, is forecast to reach multiple billions by
      2030–2033, with CAGRs frequently cited in the <span class="text-white font-semibold">15–22%+</span> range.
    </p>

    <!-- Stat cards -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-16">
      {marketStats.map((stat) => (
        <div class="stat-card rounded-2xl p-6 text-center">
          <div class="text-3xl sm:text-4xl font-extrabold tracking-tight bg-gradient-to-br from-exo-blue-bright to-exo-cyan bg-clip-text text-transparent mb-2">
            {stat.value}
          </div>
          <div class="text-sm font-semibold text-white/90 mb-1.5">{stat.label}</div>
          <div class="text-xs text-exo-silver leading-relaxed">{stat.detail}</div>
        </div>
      ))}
    </div>

    <!-- Key segments -->
    <h3 class="text-xl font-semibold mb-6 text-white/90">Key Segments</h3>
    <div class="grid sm:grid-cols-2 gap-4">
      <div class="flex items-start gap-3 glass rounded-xl p-5 border border-exo-border/40">
        <span class="w-7 h-7 rounded-lg bg-exo-blue/20 flex items-center justify-center flex-shrink-0 mt-0.5">
          <span class="text-exo-blue-bright text-sm font-bold">H</span>
        </span>
        <div>
          <p class="font-semibold text-white text-sm mb-1">Healthcare & Rehabilitation</p>
          <p class="text-xs text-white/60">Currently the largest share — stroke recovery, spinal cord injury, and mobility assistance</p>
        </div>
      </div>
      <div class="flex items-start gap-3 glass rounded-xl p-5 border border-exo-border/40">
        <span class="w-7 h-7 rounded-lg bg-exo-cyan/20 flex items-center justify-center flex-shrink-0 mt-0.5">
          <span class="text-exo-cyan text-sm font-bold">I</span>
        </span>
        <div>
          <p class="font-semibold text-white text-sm mb-1">Industrial & Logistics</p>
          <p class="text-xs text-white/60">Fastest-growing commercial application — back-support & full-body systems</p>
        </div>
      </div>
      <div class="flex items-start gap-3 glass rounded-xl p-5 border border-exo-border/40">
        <span class="w-7 h-7 rounded-lg bg-exo-blue/20 flex items-center justify-center flex-shrink-0 mt-0.5">
          <span class="text-exo-blue-bright text-sm font-bold">D</span>
        </span>
        <div>
          <p class="font-semibold text-white text-sm mb-1">Defense & Aerospace</p>
          <p class="text-xs text-white/60">Significant investment in performance augmentation programs globally</p>
        </div>
      </div>
      <div class="flex items-start gap-3 glass rounded-xl p-5 border border-exo-border/40">
        <span class="w-7 h-7 rounded-lg bg-exo-cyan/20 flex items-center justify-center flex-shrink-0 mt-0.5">
          <span class="text-exo-cyan text-sm font-bold">C</span>
        </span>
        <div>
          <p class="font-semibold text-white text-sm mb-1">Emerging Consumer & Wellness</p>
          <p class="text-xs text-white/60">Future expansion into fitness, adventure, and active-aging use cases</p>
        </div>
      </div>
    </div>

    <!-- Major players note -->
    <p class="mt-10 text-sm text-white/50 italic">
      Major players — Ekso Bionics, ReWalk Robotics, Cyberdyne (HAL), Hocoma, Parker Hannifin, Sarcos, and others — are
      already commercializing products. This is no longer a niche curiosity; it is an emerging foundational technology.
    </p>
  </section>

  <!-- ============================================ -->
  <!-- VALUE DRIVERS                                -->
  <!-- ============================================ -->
  <section class="relative max-w-5xl mx-auto px-4 sm:px-6 py-24 lg:py-32 border-t border-exo-border/40">
    <div class="mb-4 font-mono text-xs tracking-[3px] uppercase text-exo-blue-bright">Strategic Digital Real Estate</div>
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-4 leading-tight">
      Why wearableroboticexoskeletons.com<br class="hidden sm:block" /> Commands a High Acquisition Price
    </h2>
    <p class="max-w-2xl text-white/65 text-base sm:text-lg mb-14 leading-relaxed">
      This is not merely a domain. It is <span class="text-white font-semibold">strategic digital real estate</span> — the
      precise, descriptive, and authoritative name for an entire high-growth technological category.
    </p>

    <div class="space-y-8">
      {valueDrivers.map((driver) => (
        <div class="glass rounded-2xl p-6 sm:p-8 border border-exo-border/40 glow-border">
          <div class="flex flex-col sm:flex-row sm:items-start gap-5">
            <span class="text-4xl sm:text-5xl font-extrabold tracking-tighter value-number flex-shrink-0">
              {driver.num}
            </span>
            <div>
              <h3 class="text-lg sm:text-xl font-semibold text-white mb-2">{driver.title}</h3>
              <p class="text-white/65 text-sm sm:text-base leading-relaxed" set:html={driver.desc}></p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Development potential -->
    <div class="mt-12 glass rounded-2xl p-6 sm:p-8 border border-exo-border/40">
      <h3 class="text-lg font-semibold text-white mb-4">Ideal Foundation For:</h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {[
          "Flagship corporate or manufacturer site",
          "Industry news, reviews & analysis portal",
          "B2B/B2C marketplace for devices & services",
          "Research, standards & certification hub",
          "Investor/accelerator resource & media property",
          "Consumer education & adoption platform",
        ].map((item) => (
          <div class="flex items-center gap-2 text-sm text-white/70">
            <svg class="w-4 h-4 text-exo-blue-bright flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            {item}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- STRATEGIC IMPERATIVE                         -->
  <!-- ============================================ -->
  <section class="relative max-w-4xl mx-auto px-4 sm:px-6 py-24 lg:py-32 border-t border-exo-border/40">
    <div class="mb-4 font-mono text-xs tracking-[3px] uppercase text-exo-cyan">The Window</div>
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-8 leading-tight">
      A Strategic Imperative,<br class="hidden sm:block" /> Not Just an Opportunity
    </h2>
    <p class="text-white/75 text-base sm:text-lg leading-relaxed mb-8">
      The window to establish uncontested category leadership is open today but will narrow quickly as more players
      enter and awareness surges.
    </p>
    <p class="text-white/80 text-base sm:text-lg leading-relaxed mb-12">
      <strong class="text-white">wearableroboticexoskeletons.com</strong> is the cornerstone upon which a dominant brand,
      platform, or media property can be built — or the crown-jewel digital asset in a forward-looking portfolio.
    </p>

    <h3 class="text-lg font-semibold text-white mb-4">Whether you are:</h3>
    <div class="space-y-3 mb-12">
      {buyerProfiles.map((profile) => (
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-exo-blue-bright flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          <span class="text-white/75 text-sm sm:text-base">{profile}</span>
        </div>
      ))}
    </div>
    <p class="text-white/80 text-base sm:text-lg font-medium">
      …this domain delivers unmatched positioning.
    </p>
  </section>

  <!-- ============================================ -->
  <!-- FINAL CTA                                    -->
  <!-- ============================================ -->
  <section class="relative max-w-4xl mx-auto px-4 sm:px-6 py-24 lg:py-32 text-center border-t border-exo-border/40">
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-6">
      Own the Name That<br class="hidden sm:block" /> Owns the Category
    </h2>
    <p class="max-w-xl mx-auto text-white/65 text-base sm:text-lg mb-4">
      Serious, qualified inquiries only. This premium domain is offered at a <span class="text-white font-semibold">high acquisition price</span> commensurate with its category-defining nature, market timing, branding power, and long-term strategic value.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center mt-10">
      <a href={mailtoLink}
         class="cta-primary px-10 py-4 rounded-full text-white font-semibold text-lg inline-flex items-center justify-center gap-2">
        Inquire to Acquire
      </a>
      <a href={mailtoLink}
         class="cta-secondary px-10 py-4 rounded-full text-white/80 font-medium text-lg inline-flex items-center justify-center gap-2">
        Request Info Package
        <span class="text-exo-blue-bright">→</span>
      </a>
    </div>

    <!-- Trust row -->
    <div class="flex flex-wrap items-center justify-center gap-5 mt-10 text-xs text-exo-silver font-mono">
      <span class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        Escrow-Protected Transaction
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-exo-blue-bright" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        Flexible Transaction Structures
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-exo-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        Detailed Information Package Available
      </span>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- STICKY MOBILE CTA                            -->
  <!-- ============================================ -->
  <div class="sticky-cta fixed bottom-0 left-0 right-0 z-50 sm:hidden px-4 py-3">
    <a href={mailtoLink}
       class="cta-primary w-full py-3 rounded-full text-white font-semibold text-sm flex items-center justify-center gap-2">
      INQUIRE TO ACQUIRE — OWN THIS DOMAIN
    </a>
  </div>

  <!-- ============================================ -->
  <!-- FOOTER                                       -->
  <!-- ============================================ -->
  <footer class="relative border-t border-exo-border/40 bg-exo-black">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-16">
      <!-- Footer CTA -->
      <div class="text-center mb-12">
        <h3 class="text-xl sm:text-2xl font-bold text-white mb-3">
          Domain Available for Acquisition
        </h3>
        <p class="text-white/55 text-sm sm:text-base mb-6">
          Serious, qualified inquiries welcome. Flexible transaction structures available — escrow-protected.
        </p>
