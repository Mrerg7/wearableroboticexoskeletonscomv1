---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="404 — Page Not Found | Wearable Robotic Exoskeletons"
  noindex={true}
>
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="text-center">
      <div class="text-8xl sm:text-9xl font-extrabold tracking-tighter bg-gradient-to-br from-exo-blue-bright to-exo-cyan bg-clip-text text-transparent mb-6">
        404
      </div>
      <h1 class="text-2xl sm:text-3xl font-semibold text-white mb-4">Page Not Found</h1>
      <p class="text-white/50 max-w-md mx-auto mb-10 text-sm sm:text-base leading-relaxed">
        The page you're looking for doesn't exist or has been moved.
        Explore the opportunity to own the definitive domain for wearable robotic exoskeletons.
      </p>
      <a href="/"
         class="inline-flex items-center gap-2 px-8 py-3 rounded-full border border-exo-blue/40 hover:bg-exo-blue hover:text-white text-exo-blue-bright font-semibold text-sm transition-all duration-300">
        Return Home
      </a>
    </div>
  </div>
</MainLayout>
